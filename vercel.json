{
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/worksheet", "dest": "/api/worksheet.js" },
    { "src": "/ws(.*)", "dest": "/public/worksheet.html" },
    { "src": "/app(.*)", "dest": "/public/app/index.html" },
    { "src": "/privacy", "dest": "/public/privacy.html" },
    { "src": "/terms", "dest": "/public/terms.html" },
    { "src": "^/$", "dest": "/public/landing.html" },
    { "src": "/(.*)", "dest": "/public/landing.html" }
  ]
}
